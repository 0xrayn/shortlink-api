{
  "info": {
    "name": "ShortLink API",
    "description": "URL Shortener API with Redis caching and rate limiting - automated test collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "shortCode", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@test.com\",\n  \"password\": \"secret123\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201 or 400 if already registered', function () {",
                  "    pm.expect([201, 400]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@test.com\",\n  \"password\": \"secret123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has token', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.token).to.be.a('string');",
                  "    pm.collectionVariables.set('token', json.token);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Links",
      "item": [
        {
          "name": "Create Short Link",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://github.com/0xrayn/shortlink-api\"\n}"
            },
            "url": "{{baseUrl}}/shorten"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has code and short_url', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.code).to.be.a('string');",
                  "    pm.expect(json.short_url).to.be.a('string');",
                  "    pm.collectionVariables.set('shortCode', json.code);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Short Link with Custom Alias",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://github.com/0xrayn/shortlink-api\",\n  \"code\": \"my-repo\"\n}"
            },
            "url": "{{baseUrl}}/shorten"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Custom code is used', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.code).to.eql('my-repo');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Redirect (Cache Miss then Hit)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/{{shortCode}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 302 (redirect)', function () {",
                  "    pm.response.to.have.status(302);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Link Stats",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/{{shortCode}}/stats"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Click count is at least 1', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.click_count).to.be.at.least(1);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get My Links",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/my-links?page=1&limit=10"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has data and pagination', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.data).to.be.an('array');",
                  "    pm.expect(json.pagination).to.have.property('total');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get QR Code",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/{{shortCode}}/qr"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Content-Type is image/png', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.eql('image/png');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Link",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/{{shortCode}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Stats After Delete (should be 404)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/{{shortCode}}/stats"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 404 after deletion', function () {",
                  "    pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Redirect Not Found",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/this-code-does-not-exist"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 404', function () {",
                  "    pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Rate Limiting",
      "item": [
        {
          "name": "Hit Redirect Repeatedly (run 61x to trigger 429)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/my-repo"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 302 or 429', function () {",
                  "    pm.expect([302, 429]).to.include(pm.response.code);",
                  "});",
                  "",
                  "if (pm.response.code === 429) {",
                  "    pm.test('Rate limit response has retry_after', function () {",
                  "        var json = pm.response.json();",
                  "        pm.expect(json).to.have.property('retry_after');",
                  "    });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
